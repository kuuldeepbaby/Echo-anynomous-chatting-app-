<div class="w-14 h-14 rounded-full bg-gradient-to-br from-tertiary-dim to-primary-fixed-dim flex items-center justify-center overflow-hidden">
<span class="material-symbols-outlined text-on-tertiary-container text-3xl" data-icon="grain">grain</span>
</div>
<div class="absolute -top-1 -right-1 w-4 h-4 bg-secondary rounded-full border-2 border-surface-container-high"></div>
</div>
