<div class="bg-surface-container-high p-4 rounded-xl flex items-center gap-4 cursor-pointer hover:bg-surface-bright transition-all active:scale-[0.98]">
<div class="relative flex-shrink-0">
<div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary-dim to-secondary-container flex items-center justify-center overflow-hidden">
<span class="material-symbols-outlined text-surface text-3xl" data-icon="fingerprint">fingerprint</span>
</div>
<div class="absolute -top-1 -right-1 w-4 h-4 bg-secondary rounded-full border-2 border-surface-container-high"></div>
</div>
<div class="flex-grow min-w-0">
<div class="flex justify-between items-baseline mb-1">
<h3 class="font-headline font-bold text-on-surface truncate">Anonymous #402</h3>
<span class="text-[10px] font-label text-secondary uppercase tracking-widest">2m ago</span>
</div>
<p class="text-sm font-body text-on-surface-variant truncate font-semibold">Did you hear the echo tonight?</p>
</div>
