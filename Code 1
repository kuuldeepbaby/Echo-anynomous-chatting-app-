<div class="w-14 h-14 rounded-full bg-gradient-to-tr from-surface-variant to-outline-variant flex items-center justify-center overflow-hidden">
<span class="material-symbols-outlined text-on-surface-variant text-3xl" data-icon="hub">hub</span>
</div>
</div>
<div class="flex-grow min-w-0">
<div class="flex justify-between items-baseline mb-1">
